# eBilanz Backend — 12-Factor Konfiguration. Kopieren nach <repo>/.env und anpassen.
# Alle Provider-Keys ausschliesslich hier pflegen (Single Source).

# Umgebung: dev | stag | prod
APP_ENV=dev

# Netzwerk (nicht localhost; Loopback-Alias 10.0.99.1 / Netzwerk-IP)
HOST=0.0.0.0
PORT=8000
NETWORK_IP=10.0.100.3

# SQLite (relativ zum Repo-Root oder absolut)
SQLITE_PATH=./data/ebilanz.sqlite

# CORS — erlaubte Frontend-Origins (Komma-getrennt)
CORS_ORIGINS=http://10.0.100.3:5173,http://10.0.99.1:5173,http://localhost:5173

# Auth
SECRET_KEY=bitte-aendern-langer-zufallswert
SUPERADMIN_EMAIL=admin@euroblaze.de
SUPERADMIN_PASSWORD=bitte-aendern

# Vorbelegte Steuertaxonomie je Installation (amtliche Bezeichnung).
# Öffis: "Ergänzungstaxonomie Verkehrsunternehmen (JAbschlVUV)" · Simplify-ERP: "Kerntaxonomie"
DEFAULT_TAXONOMIE_ART=Kerntaxonomie

# Unternehmens-Stammdaten-Fallback je Installation (z. B. aus dem Impressum).
# Greift nur fuer Felder, die Odoo leer laesst.
COMPANY_RECHTSFORM=
COMPANY_STRASSE=
COMPANY_PLZ_ORT=
COMPANY_BUNDESLAND=
COMPANY_UST_IDNR=
COMPANY_HRB=
COMPANY_TELEFON=
COMPANY_EMAIL=
COMPANY_WEBSITE=

# Odoo-Verbindung (leer lassen, solange keine Live-Instanz; Demo-Daten greifen dann)
ODOO_URL=
ODOO_DB=
ODOO_USERNAME=
ODOO_API_KEY=
ODOO_COMPANY_ID=1
# Protokoll: jsonrpc | xmlrpc
ODOO_RPC=jsonrpc
